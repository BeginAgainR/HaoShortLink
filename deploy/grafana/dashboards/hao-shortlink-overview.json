  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "hao-prometheus"
      },
      "description": "按 HTTP method 汇总的每秒请求数。",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (method) (rate(haohttp_http_requests_total[$__rate_interval]))",
          "legendFormat": "{{method}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "HTTP 请求速率",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "hao-prometheus"
      },
      "description": "4xx 和 5xx 请求占全部 HTTP 请求的比例。",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "min": 0,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * sum(rate(haohttp_http_requests_total{status_class=\"4xx\"}[$__rate_interval])) / clamp_min(sum(rate(haohttp_http_requests_total[$__rate_interval])), 0.000000001)",
          "legendFormat": "4xx",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "100 * sum(rate(haohttp_http_requests_total{status_class=\"5xx\"}[$__rate_interval])) / clamp_min(sum(rate(haohttp_http_requests_total[$__rate_interval])), 0.000000001)",
          "legendFormat": "5xx",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "HTTP 错误比例",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "hao-prometheus"
      },
      "description": "HTTP 请求耗时的平均值、P95 和 P99。",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "min": 0,
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(haohttp_http_request_duration_seconds_sum[$__rate_interval])) / clamp_min(sum(rate(haohttp_http_request_duration_seconds_count[$__rate_interval])), 0.000000001)",
          "legendFormat": "average",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(haohttp_http_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "P95",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(haohttp_http_request_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "P99",
          "range": true,
          "refId": "C"
        }
      ],
      "title": "HTTP 请求延迟",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "hao-prometheus"
      },
      "description": "短链接创建和跳转按结果、存储或来源汇总的每秒操作数。",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "min": 0,
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (result, storage) (rate(haohttp_shortlink_create_total[$__rate_interval]))",
          "legendFormat": "create {{result}} / {{storage}}",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum by (result, source) (rate(haohttp_shortlink_redirect_total[$__rate_interval]))",
          "legendFormat": "redirect {{result}} / {{source}}",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "短链接业务操作",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "hao-prometheus"
      },
      "description": "Redis GET 的 hit、miss 和 error 占比。",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "min": 0,
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * sum by (result) (rate(haohttp_shortlink_cache_operations_total{operation=\"get\"}[$__rate_interval])) / scalar(clamp_min(sum(rate(haohttp_shortlink_cache_operations_total{operation=\"get\"}[$__rate_interval])), 0.000000001))",
          "legendFormat": "{{result}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Redis GET 结果占比",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "hao-prometheus"
      },
      "description": "MySQL 和 Redis 后端操作的每秒错误数。",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "min": 0,
          "unit": "ops"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "id": 6,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (backend, operation) (rate(haohttp_shortlink_backend_errors_total[$__rate_interval]))",
          "legendFormat": "{{backend}} / {{operation}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "后端错误速率",
      "type": "timeseries"
    }
  ],

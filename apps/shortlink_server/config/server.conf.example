# HaoShortLink local configuration example.
# Format: key=value

server.name=HaoShortLink
server.port=8080
server.thread_num=4
log.level=INFO
metrics.enabled=true

# storage.type supports memory or mysql.
# MySQL storage requires the short_links table.
storage.type=memory
mysql.host=tcp://127.0.0.1:3306
mysql.user=hao_shortlink
mysql.password=change_me
mysql.database=hao_shortlink
mysql.pool_size=4

# Redis is an optional query cache for storage.type=mysql.
# It only caches code -> original_url lookup results.
redis.enabled=false
redis.host=127.0.0.1
redis.port=6379
redis.database=0
redis.ttl_seconds=3600
redis.key_prefix=shortlink:

# Redis-backed global fixed-window limit for POST /api/short-links.
# This switch is independent of redis.enabled query caching.
rate_limit.enabled=false
rate_limit.requests=100
rate_limit.window_seconds=60
rate_limit.key_prefix=rate-limit:create:

# HaoShortLink local configuration for Docker Compose dependencies.
# Format: key=value

server.name=HaoShortLink
server.port=8080
server.thread_num=4
log.level=INFO
metrics.enabled=true

# This file is intended for shortlink_server running in the haoHTTP
# OrbStack Linux machine while MySQL and Redis run in OrbStack Docker.
storage.type=mysql
mysql.host=tcp://docker.orb.internal:13306
mysql.user=hao_shortlink
mysql.password=hao_shortlink
mysql.database=hao_shortlink
mysql.pool_size=4

# Redis is an optional query cache for storage.type=mysql.
redis.enabled=true
redis.host=docker.orb.internal
redis.port=16379
redis.database=0
redis.ttl_seconds=3600
redis.key_prefix=shortlink:

# Redis-backed global fixed-window limit for POST /api/short-links.
# This switch is independent of redis.enabled query caching.
rate_limit.enabled=false
rate_limit.requests=100
rate_limit.window_seconds=60
rate_limit.key_prefix=rate-limit:create:

# Optional fail-open Kafka access events for GET /s/:code.
# This endpoint is advertised by Kafka to processes running in the OrbStack VM.
kafka.enabled=false
kafka.bootstrap_servers=docker.orb.internal:19092
kafka.topic=hao-shortlink.access-events.v1
kafka.client_id=hao-shortlink-server-vm
kafka.queue_max_messages=10000
kafka.message_timeout_ms=10000
kafka.linger_ms=5
kafka.shutdown_timeout_ms=3000
